    "renderer.private_particles",
    "renderer.stimulus_volume"
  ],
  "exclusive_groups": {
    "projection_target": "breathing-room",
    "right_primary_action": "projection-target-reset"
  },
  "android_manifest": {
    "permissions": [],
    "uses_features": [],
    "activities": [],
    "services": [],
    "queries": []
  },
