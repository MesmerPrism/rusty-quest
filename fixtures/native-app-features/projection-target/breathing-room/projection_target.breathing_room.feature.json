{
  "schema": "rusty.quest.native_app_feature.v1",
  "feature_id": "projection_target.breathing_room",
  "module_path": "projection-target/breathing-room",
  "module_kind": "projection-target",
  "settings_surface": {
    "authority": "rusty.quest.native_app_settings.v1",
    "adapter": "runtime_profile"
  },
  "owner_lane": "rusty-quest",
  "status": "public-app-feature",
  "description": "Breathing Room projection-target controls with PMB-compatible Manifold, synthetic, or direct native controller-state breath sources.",
  "provides": [
    "projection_target.breathing_room"
  ],
  "depends_on": [
    "quest.native.openxr_vulkan_base",
    "camera.hwb"
  ],
  "incompatible_with": [
