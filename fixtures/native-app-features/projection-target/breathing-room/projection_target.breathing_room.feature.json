    "set": {
      "debug.rustyquest.native_renderer.projection.target.breath.high_rate_json_payload": "false",
      "debug.rustyquest.native_renderer.projection.target.controls": "true",
      "debug.rustyquest.native_renderer.projection.target.scale": "1.0"
    },
    "clear_families": [
      "projection_target"
    ],
    "expected_render_modes": [
      "custom-stereo-projection"
    ]
  },
  "build_inputs": {
    "env": [],
    "assets": [],
    "shaders": []
  },
  "markers": {
    "required": [
      "projectionTargetControlsEnabled=true",
      "projectionTargetBreathHighRateJsonPayload=false"
    ],
    "forbidden": [
      "privateParticleRecenterInputEnabled=true"
    ]
  },
  "validation": {
    "quick": [
      "powershell -NoProfile -ExecutionPolicy Bypass -File tools/checks/Test-NativeRendererProjectionTargetStatic.ps1 -RepoRoot ."
    ],
    "standard": [],
    "device": []
  },
  "public_private_boundary": "Breathing Room projection-target control belongs to Rusty Quest; PMB profile semantics stay in the package lane, while direct-controller-state is a Rusty Quest-native comparison source that must not require Manifold transport."
