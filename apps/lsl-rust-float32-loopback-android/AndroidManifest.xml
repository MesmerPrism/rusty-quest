<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="io.github.mesmerprism.rustyquest.lslrustfloat32loopback">
    <uses-permission android:name="android.permission.INTERNET" />
    <application android:allowBackup="false" android:debuggable="true"
        android:label="Rusty LSL Float32 Loopback" android:theme="@android:style/Theme.Material.Light.NoActionBar">
        <activity android:name=".Float32LoopbackActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="com.oculus.intent.category.2D" />
            </intent-filter>
        </activity>
    </application>
</manifest>
