{
  "$schema": "https://github.com/MesmerPrism/rusty-morphospace-work-environment/schemas/iteration-unit.schema.json",
  "schema": "rusty.morphospace.workflow.iteration_unit.v1",
  "unit_id": "mod-001",
  "project_id": "spatial-camera-panel",
  "status": "accepted",
  "objective": "Classify the ECS and surface-particle family into app shell, Matter state/simulation, Lattice relation, Optics appearance, and Quest/Spatial adapter responsibilities.",
  "change_categories": ["authority", "module-layout", "validation", "public-private-boundary"],
  "instruction_impact": "update",
  "instruction_surfaces": [
    {
      "surface_kind": "agents",
      "path": "../../../AGENTS.md",
      "owner": "quest-repo",
      "change_reason": "Route the classified app and reusable particle ownership boundaries.",
      "action": "update",
      "status": "complete",
      "validation": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/check_all.ps1",
      "skill_id": null
    },
    {
      "surface_kind": "readme",
      "path": "../README.md",
      "owner": "spatial-app",
      "change_reason": "Map app-local carrier behavior against the reusable candidate boundary.",
      "action": "update",
      "status": "complete",
      "validation": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/Test-SpatialCameraPanelAndroid.ps1",
      "skill_id": null
    },
    {
      "surface_kind": "skill",
      "path": "<skills-root>/rusty-morphospace-context/SKILL.md",
      "owner": "quest-repo",
      "change_reason": "Record the accepted particle lane routing.",
      "action": "update",
      "status": "complete",
      "validation": "planning roadmap validation",
      "skill_id": "rusty-morphospace-context"
    },
    {
      "surface_kind": "skill",
      "path": "<skills-root>/system-engineering/SKILL.md",
      "owner": "quest-repo",
      "change_reason": "Record the classified authority and contract boundary.",
      "action": "update",
      "status": "complete",
      "validation": "planning roadmap validation",
      "skill_id": "system-engineering"
    },
    {
      "surface_kind": "skill",
      "path": "<skills-root>/rust-work-graph/SKILL.md",
      "owner": "quest-repo",
      "change_reason": "Record particle source roots and extraction-impact scan routing.",
      "action": "update",
      "status": "complete",
      "validation": "scoped graph snapshot",
      "skill_id": "rust-work-graph"
    }
  ],
  "instruction_none_justification": null,
  "prerequisites": ["wf-003"],
  "allowed_repositories": [
    {
      "repo_id": "spatial-app",
      "allowed_paths": ["README.md", "app/", "native-receipt/", "morphospace/"]
    },
    {
      "repo_id": "quest-repo",
      "allowed_paths": ["AGENTS.md", "README.md", "docs/", "tools/"]
    },
    {
      "repo_id": "matter",
      "allowed_paths": ["docs/", "fixtures/", "schemas/"]
    },
    {
      "repo_id": "lattice",
      "allowed_paths": ["docs/", "fixtures/", "schemas/"]
    },
    {
      "repo_id": "optics",
      "allowed_paths": ["docs/", "fixtures/", "schemas/"]
    },
    {
      "repo_id": "work-environment",
      "allowed_paths": ["AGENTS.md", "README.md", "skills/"]
    },
    {
      "repo_id": "installed-skills",
      "allowed_paths": ["rusty-morphospace-context/", "system-engineering/", "rust-work-graph/"]
    }
  ],
  "non_scope": [
    "Moving implementation code before the classification is accepted.",
    "Changing runtime defaults, package permissions, or feature activation.",
    "Private shader or study semantics.",
    "Live device validation."
  ],
  "acceptance": [
    {
      "acceptance_id": "authority-map",
      "proof": "Every particle concern has one owner and an explicit does-not-own boundary.",
      "command": "candidate and source-map validation"
    },
    {
      "acceptance_id": "source-impact-map",
      "proof": "A scoped graph identifies app-local carrier, state, shader, fixture, validation, and adapter roots without authorizing source movement.",
      "command": "scoped rust-work-graph snapshot"
    },
    {
      "acceptance_id": "inactive-baseline",
      "proof": "The workflow feature lock still disables surface-particle-runtime and the app static gate passes.",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/Test-SpatialCameraPanelAndroid.ps1"
    }
  ],
  "risk_tier": "standard",
  "device_requirement": "none",
  "validation": [
    {
      "profile_id": "quick",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/checks/Test-SpatialCameraPanelWorkflowStatic.ps1 -RepoRoot ."
    },
    {
      "profile_id": "standard",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/Test-SpatialCameraPanelAndroid.ps1"
    }
  ],
  "outputs": [
    "Accepted cross-lane particle authority map.",
    "Updated particle candidate record and source-impact graph.",
    "Instruction synchronization receipt."
  ],
  "commit_policy": "Commit the classification and instruction map before any contract extraction.",
  "push_checkpoint": "integration-batch"
}
